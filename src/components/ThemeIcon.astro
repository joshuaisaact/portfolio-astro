---
import { Sun, Moon } from "lucide-astro";
---

<button
  id="themeToggle"
  aria-label="Toggle theme"
  class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-(--theme-5)"
>
  <span class="relative inline-flex size-5">
    <Sun
      class="absolute inset-0 size-5 text-gray-900 dark:text-gray-200 transition-[opacity,filter,scale,rotate] duration-300 ease-[cubic-bezier(0.2,0,0,1)] scale-[0.25] opacity-0 blur-[4px] hover:rotate-45 dark:scale-100 dark:opacity-100 dark:blur-[0px]"
      aria-hidden="true"
    />
    <Moon
      class="absolute inset-0 size-5 text-gray-900 dark:text-gray-200 transition-[opacity,filter,scale,rotate] duration-300 ease-[cubic-bezier(0.2,0,0,1)] scale-100 opacity-100 blur-[0px] hover:rotate-12 dark:scale-[0.25] dark:opacity-0 dark:blur-[4px]"
      aria-hidden="true"
    />
  </span>
</button>

<script>
  const button = document.getElementById("themeToggle");

  button?.addEventListener("click", () => {
    document.documentElement.classList.toggle("dark");
    const isDark = document.documentElement.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
