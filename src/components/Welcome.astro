---
import { Image } from "astro:assets";
import { Palette } from "lucide-astro";
import Button from "./Button.astro";
import profilePicture from "../assets/focused.png";
import teletextPicture from "../assets/teletext.svg";
---

<div id="container">
  <section
    class="relative py-8 sm:py-12 border-t border-gray-200 dark:border-gray-800"
    aria-label="Introduction"
  >
    <section
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 justify-center lg:justify-items-end lg:items-center py-8 sm:py-12 md:py-16 lg:py-24 mx-0 sm:mx-4 lg:mx-8"
    >
      <div
        class="welcome-content-col order-2 lg:order-1 p-2 sm:p-4 justify-self-center lg:justify-self-end space-y-6 stagger-in"
        data-stagger-delay="0"
      >
        <div class="space-y-4">
          <h1
            class="text-xl sm:text-2xl md:text-3xl lg:text-4xl dark:text-gray-200 leading-normal font-semibold"
          >
            Hi, I&apos;m{" "}
            <span class="text-(--theme-5) font-bold">Josh</span><span class="ceefax-hide"> 👋</span>
          </h1>
        </div>

        <div class="prose dark:prose-invert max-w-none">
          <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300">
            I&apos;m an AI engineer at <a
              href="https://www.granola.ai/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-(--theme-5) hover:underline font-semibold"
              >Granola</a
            >, where I build AI features in TypeScript.
            Outside work I write Zig and Go on systems-level projects. In a past
            life I sold AI software to hedge fund managers. I write
            about engineering on my <a
              class="text-(--theme-5) hover:underline font-semibold"
              href="/blog">blog</a
            >.
          </p>
        </div>

        <!-- Theme picker -->
        <Button id="welcomeThemeBtn" variant="primary" class="theme-switcher">
          <Palette class="w-4 h-4" />
          Change Theme
        </Button>
      </div>

      <div class="welcome-image-col order-1 lg:order-2 flex justify-center items-start lg:justify-self-center stagger-in" data-stagger-delay="100">
        <div
          class="w-48 h-48 sm:w-64 sm:h-64 md:w-80 md:h-80 lg:w-80 lg:h-80 shrink-0"
        >
          <Image
            src={profilePicture}
            alt="Josh Tuddenham"
            width={400}
            height={400}
            loading="eager"
            fetchpriority="high"
            class="profile-default w-full h-full rounded-full border-4 border-(--theme-5) dark:brightness-90 object-cover"
          />
          <Image
            src={teletextPicture}
            alt="Josh Tuddenham"
            width={400}
            height={400}
            class="profile-ceefax hidden w-full h-full object-contain"
          />
        </div>
      </div>
    </section>
  </section>
</div>

<script>
  const modal = document.getElementById("themeModal") as HTMLDialogElement | null;
  document.getElementById("welcomeThemeBtn")?.addEventListener("click", () => modal?.showModal());
</script>
