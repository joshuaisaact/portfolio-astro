---
import { Image } from "astro:assets";
import profilePicture from "../assets/focused.png";
import teletextPicture from "../assets/teletext.svg";
---

<div id="container">
  <section
    class="relative py-8 sm:py-12 border-t border-gray-200 dark:border-gray-800"
    aria-label="Introduction"
  >
    <section
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 justify-center lg:justify-items-end py-8 sm:py-12 md:py-16 lg:py-24 mx-0 sm:mx-4 lg:mx-8"
    >
      <div
        class="order-2 lg:order-1 p-2 sm:p-4 justify-self-center lg:justify-self-end space-y-6"
      >
        <div class="space-y-4">
          <h1
            class="text-xl sm:text-2xl md:text-3xl lg:text-4xl dark:text-gray-200 leading-normal font-semibold"
          >
            Hi, I&apos;m{" "}
            <span class="text-(--theme-5) font-bold">Josh</span><span class="ceefax-hide"> 👋</span>
          </h1>
        </div>

        <div class="prose dark:prose-invert max-w-none space-y-4">
          <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300">
            I&apos;m a senior engineer at <a
              href="https://www.letsdothis.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-(--theme-5) hover:underline font-semibold"
              >Let&apos;s Do This</a
            >, where I build AI agents and platform features in TypeScript.
            Outside work I write Zig, Go, and whatever else catches my interest.
          </p>

          <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300">
            I went from pitching portfolio managers to writing hash tables in Zig.
          </p>

          <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300">
            I write about engineering on my <a
              class="text-(--theme-5) hover:underline font-semibold"
              href="/blog">blog</a
            >.
          </p>
        </div>

        <!-- Theme Switcher Dropdown -->
        <div class="theme-switcher relative inline-block">
          <button
            id="themeSwitcherToggle"
            class="text-xs px-3 py-1.5 rounded-full border border-gray-300 dark:border-gray-600 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors inline-flex items-center gap-1.5"
          >
            <span id="themeSwitcherLabel">Theme</span>
            <svg
              class="w-3 h-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path></svg
            >
          </button>
          <div
            id="themeSwitcherMenu"
            class="hidden absolute left-0 mt-1 w-36 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-lg z-50 overflow-hidden"
          >
            <button
              data-theme-choice="default"
              class="w-full text-left text-xs px-3 py-2 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
            >
              Default
            </button>
            <button
              data-theme-choice="ceefax"
              class="w-full text-left text-xs px-3 py-2 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
            >
              Ceefax
            </button>
          </div>
        </div>
      </div>

      <div class="order-1 lg:order-2 flex justify-center items-start">
        <div
          class="w-48 h-48 sm:w-64 sm:h-64 md:w-80 md:h-80 lg:w-[400px] lg:h-[400px] shrink-0"
        >
          <Image
            src={profilePicture}
            alt="Josh Tuddenham"
            width={400}
            height={400}
            loading="eager"
            fetchpriority="high"
            class="profile-default w-full h-full rounded-full border-4 border-(--theme-5) cursor-pointer dark:brightness-90 object-cover"
          />
          <Image
            src={teletextPicture}
            alt="Josh Tuddenham"
            width={400}
            height={400}
            class="profile-ceefax hidden w-full h-full object-contain"
          />
        </div>
      </div>
    </section>
  </section>
</div>

<script>
  function initThemeSwitcher() {
    const toggle = document.getElementById("themeSwitcherToggle");
    const menu = document.getElementById("themeSwitcherMenu");
    const label = document.getElementById("themeSwitcherLabel");
    const buttons = document.querySelectorAll("[data-theme-choice]");
    const current = new URLSearchParams(window.location.search).get("theme") || "default";

    const names: Record<string, string> = {
      default: "Default",
      ceefax: "Ceefax",
    };

    if (label && current !== "default") {
      label.textContent = names[current] ?? "Theme";
    }

    // Mark active item
    buttons.forEach((btn) => {
      const choice = (btn as HTMLElement).dataset.themeChoice;
      if (choice === current) {
        btn.classList.add("font-bold", "text-gray-900", "dark:text-white");
        btn.setAttribute("data-active", "true");
      }
    });

    // Toggle dropdown
    toggle?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
        menu?.classList.add("hidden");
      }
    });

    // Theme selection — navigate with ?theme= param
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const selected = (btn as HTMLElement).dataset.themeChoice ?? "default";
        if (selected === current) {
          menu?.classList.add("hidden");
          return;
        }
        const url = new URL(window.location.href);
        if (selected === "default") {
          url.searchParams.delete("theme");
        } else {
          url.searchParams.set("theme", selected);
        }
        window.location.href = url.toString();
      });
    });
  }

  initThemeSwitcher();
</script>
