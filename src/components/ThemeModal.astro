---
import Button from "./Button.astro";

const themes = [
  {
    id: "default",
    label: "Default",
    flavour: "For fans of vanilla. Nothing wrong with a classic.",
    preview: `<svg viewBox="0 0 160 100" xmlns="http://www.w3.org/2000/svg">
      <rect width="160" height="100" fill="#1f2937"/>
      <rect width="160" height="16" fill="#111827"/>
      <rect x="8" y="5" width="20" height="6" rx="2" fill="#374151"/>
      <rect x="90" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="106" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="122" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="138" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="8" y="26" width="80" height="8" rx="2" fill="#4b5563"/>
      <rect x="8" y="40" width="144" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="48" width="136" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="56" width="120" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="68" width="44" height="24" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
      <rect x="58" y="68" width="44" height="24" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
      <rect x="108" y="68" width="44" height="24" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
    </svg>`,
  },
  {
    id: "ceefax",
    label: "Ceefax",
    flavour: "As seen between the test card and a snooker repeat on BBC Two. Your TV licence has never looked this good.",
    preview: `<svg viewBox="0 0 160 100" xmlns="http://www.w3.org/2000/svg">
      <rect width="160" height="100" fill="#000"/>
      <rect width="160" height="14" fill="#ff0000"/>
      <rect x="4" y="4" width="60" height="6" fill="#fff" opacity="0.9"/>
      <rect x="130" y="4" width="26" height="6" fill="#ffff00"/>
      <rect x="4" y="22" width="100" height="6" fill="#00ffff"/>
      <rect x="4" y="32" width="152" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="40" width="144" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="48" width="136" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="56" width="120" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="0" y="86" width="40" height="14" fill="#ff0000"/>
      <rect x="40" y="86" width="40" height="14" fill="#00ff00"/>
      <rect x="80" y="86" width="40" height="14" fill="#ffff00"/>
      <rect x="120" y="86" width="40" height="14" fill="#00ffff"/>
    </svg>`,
  },
];
---

<dialog
  id="themeModal"
  class="m-auto p-0 rounded-xl shadow-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 backdrop:bg-black/50 backdrop:backdrop-blur-sm"
>
  <div class="p-5 w-[600px]">
    <div class="grid grid-cols-2 gap-3">
      {
        themes.map(({ id, label, flavour, preview }) => (
          <button
            data-nav-theme={id}
            data-flavour={flavour}
            class="group flex flex-col rounded-lg border-2 border-gray-200 dark:border-gray-700 overflow-hidden cursor-pointer transition-colors hover:border-gray-400 dark:hover:border-gray-500 data-[active]:border-(--theme-5) data-[active]:dark:border-(--theme-5)"
          >
            <div class="w-full" set:html={preview} />
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 px-3 py-2 text-left group-data-[active]:text-gray-900 group-data-[active]:dark:text-white">
              {label}
            </span>
          </button>
        ))
      }
    </div>

    <p
      id="themeFlavour"
      class="mt-4 px-2 text-base text-gray-500 dark:text-white min-h-[3rem]"
    >
    </p>

    <div class="flex justify-end mt-4">
      <Button id="themeConfirmBtn" variant="primary">Apply</Button>
    </div>
  </div>
</dialog>

<script define:vars={{ themes }}>
  const modal = document.getElementById("themeModal");
  const flavourEl = document.getElementById("themeFlavour");
  const confirmBtn = document.getElementById("themeConfirmBtn");

  if (modal) {
    const current = new URLSearchParams(window.location.search).get("theme") ?? "default";
    let selected = current;

    const cards = modal.querySelectorAll("[data-nav-theme]");

    // Set initial active state and flavour text
    cards.forEach((btn) => {
      if (btn.dataset.navTheme === current) {
        btn.dataset.active = "";
        if (flavourEl) flavourEl.textContent = btn.dataset.flavour ?? "";
      }
    });

    // Card selection — update state without navigating
    cards.forEach((btn) => {
      btn.addEventListener("click", () => {
        cards.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        selected = btn.dataset.navTheme ?? "default";
        if (flavourEl) flavourEl.textContent = btn.dataset.flavour ?? "";
      });
    });

    // Confirm — navigate to selected theme
    confirmBtn?.addEventListener("click", () => {
      const url = new URL(window.location.href);
      if (selected === "default") {
        url.searchParams.delete("theme");
      } else {
        url.searchParams.set("theme", selected);
      }
      window.location.href = url.toString();
    });

    // Close on backdrop click
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.close();
    });
  }
</script>
