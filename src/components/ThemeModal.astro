---
import Button from "./Button.astro";

const themes = [
  {
    id: "default",
    label: "Default",
    flavour: "For fans of vanilla. Nothing wrong with a classic.",
    preview: `<svg viewBox="0 0 160 80" xmlns="http://www.w3.org/2000/svg">
      <rect width="160" height="80" fill="#1f2937"/>
      <rect width="160" height="16" fill="#111827"/>
      <rect x="8" y="5" width="20" height="6" rx="2" fill="#374151"/>
      <rect x="90" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="106" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="122" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="138" y="5" width="12" height="5" rx="1" fill="#374151"/>
      <rect x="8" y="26" width="80" height="8" rx="2" fill="#4b5563"/>
      <rect x="8" y="40" width="144" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="48" width="136" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="56" width="120" height="4" rx="1" fill="#374151"/>
      <rect x="8" y="64" width="44" height="12" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
      <rect x="58" y="64" width="44" height="12" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
      <rect x="108" y="64" width="44" height="12" rx="3" fill="#111827" stroke="#374151" stroke-width="1"/>
    </svg>`,
  },
  {
    id: "ceefax",
    label: "Ceefax",
    flavour: "As seen between the test card and a snooker repeat on BBC Two. Your TV licence has never looked this good.",
    preview: `<svg viewBox="0 0 160 80" xmlns="http://www.w3.org/2000/svg">
      <rect width="160" height="80" fill="#000"/>
      <rect width="160" height="14" fill="#ff0000"/>
      <rect x="4" y="4" width="60" height="6" fill="#fff" opacity="0.9"/>
      <rect x="130" y="4" width="26" height="6" fill="#ffff00"/>
      <rect x="4" y="22" width="100" height="6" fill="#00ffff"/>
      <rect x="4" y="32" width="152" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="40" width="144" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="48" width="136" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="4" y="56" width="120" height="4" fill="#00ffff" opacity="0.7"/>
      <rect x="0" y="66" width="40" height="14" fill="#ff0000"/>
      <rect x="40" y="66" width="40" height="14" fill="#00ff00"/>
      <rect x="80" y="66" width="40" height="14" fill="#ffff00"/>
      <rect x="120" y="66" width="40" height="14" fill="#00ffff"/>
    </svg>`,
  },
];
---

<dialog
  id="themeModal"
  aria-label="Select theme"
  class="m-auto p-0 rounded-xl shadow-2xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 backdrop:bg-black/50 backdrop:backdrop-blur-sm w-[calc(100%-2rem)] max-w-[600px] max-h-[calc(100dvh-2rem)] overflow-y-auto"
>
  <div class="p-4 sm:p-5 w-full">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
      {
        themes.map(({ id, label, flavour, preview }) => (
          <button
            data-nav-theme={id}
            data-flavour={flavour}
            class="group flex flex-col rounded-lg border-2 border-gray-200 dark:border-gray-700 overflow-hidden cursor-pointer transition-colors hover:border-gray-400 dark:hover:border-gray-500 data-[active]:border-(--theme-5) data-[active]:dark:border-(--theme-5)"
          >
            <div class="w-full" set:html={preview} />
            <span class="text-base font-semibold text-gray-700 dark:text-gray-300 px-3 py-2 text-left group-data-[active]:text-gray-900 group-data-[active]:dark:text-white">
              {label}
            </span>
          </button>
        ))
      }
    </div>

    <p
      id="themeFlavour"
      class="mt-4 px-2 text-base text-gray-500 dark:text-white min-h-[4.5rem] sm:min-h-[3rem]"
    >
    </p>

    <div class="flex justify-end mt-4">
      <Button id="themeConfirmBtn" variant="primary">Apply</Button>
    </div>
  </div>
</dialog>

<script define:vars={{ themes }}>
  const modal = document.getElementById("themeModal");
  const flavourEl = document.getElementById("themeFlavour");
  const confirmBtn = document.getElementById("themeConfirmBtn");

  if (modal) {
    const current = new URLSearchParams(window.location.search).get("theme") ?? "default";
    let selected = current;

    const cards = modal.querySelectorAll("[data-nav-theme]");

    // Set initial active state and flavour text
    cards.forEach((btn) => {
      if (btn.dataset.navTheme === current) {
        btn.dataset.active = "";
        if (flavourEl) flavourEl.textContent = btn.dataset.flavour ?? "";
      }
    });

    // Card selection — update state without navigating
    cards.forEach((btn) => {
      btn.addEventListener("click", () => {
        cards.forEach((b) => delete b.dataset.active);
        btn.dataset.active = "";
        selected = btn.dataset.navTheme ?? "default";
        if (flavourEl) flavourEl.textContent = btn.dataset.flavour ?? "";
      });
    });

    // Confirm — navigate to selected theme
    confirmBtn?.addEventListener("click", () => {
      const url = new URL(window.location.href);
      if (selected === "default") {
        url.searchParams.delete("theme");
      } else {
        url.searchParams.set("theme", selected);
      }
      window.location.href = url.toString();
    });

    function closeModal() {
      modal.classList.add("modal-closing");
      modal.addEventListener(
        "animationend",
        () => {
          modal.classList.remove("modal-closing");
          modal.close();
        },
        { once: true }
      );
    }

    // Close on backdrop click
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });

    // Intercept Escape key close
    modal.addEventListener("cancel", (e) => {
      e.preventDefault();
      closeModal();
    });
  }
</script>

<style>
  @keyframes modal-in {
    from { opacity: 0; filter: blur(4px); transform: scale(0.97); }
    to   { opacity: 1; filter: blur(0);   transform: scale(1); }
  }

  @keyframes modal-out {
    from { opacity: 1; filter: blur(0);   transform: scale(1); }
    to   { opacity: 0; filter: blur(6px); transform: scale(0.97); }
  }

  @keyframes backdrop-out {
    from { background: rgb(0 0 0 / 0.5); backdrop-filter: blur(4px); }
    to   { background: rgb(0 0 0 / 0);   backdrop-filter: blur(0); }
  }

  dialog[open] {
    animation: modal-in 0.2s ease-out forwards;
  }

  dialog.modal-closing {
    animation: modal-out 0.25s ease-in forwards;
  }

  dialog.modal-closing::backdrop {
    animation: backdrop-out 0.25s ease-in forwards;
  }
</style>
