---
import "../styles/global.css";
import "@fontsource-variable/fraunces";
import "@fontsource-variable/ibm-plex-sans";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Joshua Tuddenham | Full-Stack Engineer",
  description = "Full-stack engineer specializing in modern web technologies. View my latest projects and blog posts.",
  image = "https://joshtuddenham.dev/og-image.jpg",
  canonicalURL = "https://joshtuddenham.dev/",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="sitemap" href="/sitemap-index.xml" />


    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Josh Tuddenham" />
    <meta
      name="keywords"
      content="Full-Stack Engineer, Software Developer, React, TypeScript, Node.js, Enterprise Software, Capital Markets Technology, Web Development, JavaScript, Next.js, Astro"
    />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#111827"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Josh Tuddenham" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Josh Tuddenham Portfolio" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <style is:inline>
      html {
        background-color: white;
      }
      @media (prefers-color-scheme: dark) {
        html {
          background-color: #111827;
        }
      }
      html.dark {
        background-color: #111827;
      }
      html.theme-ceefax {
        background-color: #000000 !important;
      }
      body {
        background-color: inherit;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }
    </style>
    <script is:inline>
      function getSiteTheme() {
        return new URLSearchParams(window.location.search).get("theme") || "default";
      }

      function applyTheme() {
        const siteTheme = getSiteTheme();

        // Remove all theme classes
        document.documentElement.classList.remove("theme-ceefax");

        if (siteTheme === "ceefax") {
          // Ceefax forces dark mode, strip antialiasing
          document.documentElement.classList.add("dark", "theme-ceefax");
          document.documentElement.classList.remove("antialiased");
          return;
        }

        // Default theme: respect dark/light preference
        const theme = (() => {
          const localStorageTheme = localStorage?.getItem("theme") ?? "";
          if (["dark", "light"].includes(localStorageTheme)) {
            return localStorageTheme;
          }
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
          }
          return "light";
        })();

        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }

        window.localStorage.setItem("theme", theme);
      }

      // Append ?theme= to all internal links so it persists on navigation
      function propagateTheme() {
        var theme = getSiteTheme();
        if (theme === "default") return;
        document.addEventListener("DOMContentLoaded", function () {
          document.querySelectorAll('a[href^="/"]').forEach(function (a) {
            var url = new URL(a.href, window.location.origin);
            url.searchParams.set("theme", theme);
            a.href = url.toString();
          });
        });
      }

      applyTheme();
      propagateTheme();

      // Ceefax enhancements: scanlines, live clock, image pixelation
      function ceefaxInit() {
        if (getSiteTheme() !== "ceefax") return;

        document.addEventListener("DOMContentLoaded", function () {
          // Page number mapping
          var path = window.location.pathname.replace(/\/+$/, "") || "/";
          var pageMap = {
            "/": "100",
            "/blog": "200",
            "/projects": "300"
          };
          var pageNum = pageMap[path];
          if (!pageNum) {
            // Blog posts get 2xx, project pages get 3xx
            if (path.startsWith("/blog/")) pageNum = "2" + String(Math.abs(path.split("").reduce(function(a,c){return ((a<<5)-a)+c.charCodeAt(0)|0},0)) % 100).padStart(2,"0");
            else if (path.startsWith("/projects/")) pageNum = "3" + String(Math.abs(path.split("").reduce(function(a,c){return ((a<<5)-a)+c.charCodeAt(0)|0},0)) % 100).padStart(2,"0");
            else pageNum = "100";
          }

          // Header bar with live clock
          var hdr = document.createElement("div");
          hdr.id = "ceefax-header";
          document.body.insertBefore(hdr, document.body.firstChild);

          var days = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
          var months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
          var d = new Date();
          var day = days[d.getDay()];
          var dt = String(d.getDate()).padStart(2," ");
          var mon = months[d.getMonth()];

          var leftSpan = document.createElement("span");
          leftSpan.textContent = "P" + pageNum + " CEEFAX " + pageNum + " " + day + " " + dt + " " + mon;
          hdr.appendChild(leftSpan);

          var timeSpan = document.createElement("span");
          timeSpan.className = "ceefax-time";
          hdr.appendChild(timeSpan);

          function updateTime() {
            var d = new Date();
            var h = String(d.getHours()).padStart(2,"0");
            var m = String(d.getMinutes()).padStart(2,"0");
            var s = String(d.getSeconds()).padStart(2,"0");
            timeSpan.textContent = h + ":" + m + "/" + s;
          }
          updateTime();
          setInterval(updateTime, 1000);

          // Scanline overlay
          var sl = document.createElement("div");
          sl.id = "ceefax-scanlines";
          document.body.appendChild(sl);

          // Fastext navigation bar — links carry ?theme=ceefax
          var ft = document.createElement("div");
          ft.id = "ceefax-fastext";
          ft.innerHTML =
            '<a href="/?theme=ceefax">HOME</a>' +
            '<a href="/blog?theme=ceefax">BLOG</a>' +
            '<a href="/projects?theme=ceefax">PROJECTS</a>' +
            '<a href="#" id="ceefax-theme-btn">DEFAULT</a>';
          document.body.appendChild(ft);
          document.getElementById("ceefax-theme-btn").addEventListener("click", function (e) {
            e.preventDefault();
            // Strip ?theme param to go back to default
            var url = new URL(window.location.href);
            url.searchParams.delete("theme");
            window.location.href = url.toString();
          });

          // Pixelate images via canvas downscale
          document.querySelectorAll("img").forEach(function (img) {
            var doPixelate = function () {
              try {
                var w = img.naturalWidth;
                var h = img.naturalHeight;
                if (!w || !h) return;
                var factor = 12;
                var sw = Math.max(Math.round(w / factor), 1);
                var sh = Math.max(Math.round(h / factor), 1);
                var c = document.createElement("canvas");
                c.width = sw;
                c.height = sh;
                var ctx = c.getContext("2d");
                if (!ctx) return;
                ctx.imageSmoothingEnabled = false;
                ctx.drawImage(img, 0, 0, sw, sh);
                var c2 = document.createElement("canvas");
                c2.width = w;
                c2.height = h;
                var ctx2 = c2.getContext("2d");
                if (!ctx2) return;
                ctx2.imageSmoothingEnabled = false;
                ctx2.drawImage(c, 0, 0, w, h);
                img.src = c2.toDataURL();
                img.srcset = "";
                img.classList.add("ceefax-pixelated");
              } catch (e) {}
            };
            if (img.complete && img.naturalWidth) doPixelate();
            else img.addEventListener("load", doPixelate);
          });
        });
      }
      ceefaxInit();
    </script>
  </head>
  <body class="font-ibm-plex min-h-screen">
    <slot />
  </body>
</html>
