---
import "../styles/global.css";
import "@fontsource-variable/fraunces";
import "@fontsource-variable/ibm-plex-sans";
import ThemeModal from "../components/ThemeModal.astro";
import { validThemeIds } from "../config/themes";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Joshua Tuddenham | Full-Stack Engineer",
  description = "Full-stack engineer specializing in modern web technologies. View my latest projects and blog posts.",
  image = "https://joshtuddenham.dev/og-image.jpg",
  canonicalURL = "https://joshtuddenham.dev/",
} = Astro.props;
---

<!doctype html>
<html lang="en-GB" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="sitemap" href="/sitemap-index.xml" />


    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Josh Tuddenham" />
    <meta
      name="keywords"
      content="Full-Stack Engineer, Software Developer, React, TypeScript, Node.js, Enterprise Software, Capital Markets Technology, Web Development, JavaScript, Next.js, Astro"
    />
    <link rel="canonical" href={canonicalURL} />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#111827"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Josh Tuddenham" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Josh Tuddenham Portfolio" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <style is:inline>
      html {
        background-color: white;
      }
      @media (prefers-color-scheme: dark) {
        html {
          background-color: #111827;
        }
      }
      html.dark {
        background-color: #111827;
      }
      html.theme-ceefax {
        background-color: #000000 !important;
      }
      html.theme-myspace {
        background-color: #d2d2d2 !important;
      }
      body {
        background-color: inherit;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }
    </style>
    <script is:inline define:vars={{ validThemeIds }}>
      function getSiteTheme() {
        var theme = new URLSearchParams(window.location.search).get("theme") || "default";
        return validThemeIds.includes(theme) ? theme : "default";
      }

      function applyTheme() {
        var siteTheme = getSiteTheme();
        document.documentElement.classList.remove("theme-ceefax", "theme-myspace");
        if (siteTheme === "ceefax") {
          document.documentElement.classList.add("dark", "theme-ceefax");
          document.documentElement.classList.remove("antialiased");
          return;
        }
        if (siteTheme === "myspace") {
          document.documentElement.classList.add("theme-myspace");
          // No 'dark' class — MySpace default was light mode
          return;
        }
        var stored = localStorage?.getItem("theme") ?? "";
        var theme = ["dark", "light"].includes(stored)
          ? stored
          : window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.classList.toggle("dark", theme === "dark");
        window.localStorage.setItem("theme", theme);
      }

      applyTheme();
    </script>
  </head>
  <body class="font-ibm-plex min-h-screen">
    <slot />
    <ThemeModal />
  </body>
  <script>
    import { validThemeIds } from '../config/themes';

    function getSiteTheme(): string {
      const theme = new URLSearchParams(window.location.search).get('theme') || 'default';
      return validThemeIds.includes(theme) ? theme : 'default';
    }

    const siteTheme = getSiteTheme();

    // Propagate ?theme= through all internal links
    if (siteTheme !== 'default') {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="/"]').forEach((a) => {
        const url = new URL(a.href, window.location.origin);
        url.searchParams.set('theme', siteTheme);
        a.href = url.toString();
      });
    }

    // MySpace: inject 2-column profile layout
    if (siteTheme === 'myspace') {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
      const moods = ['💻 shipping code', '☕ caffeinating', '📖 reading docs', '🐛 debugging'];
      const mood = moods[Math.floor(Math.random() * moods.length)];

      // Try to reuse profile pic from the page
      const existingImg = document.querySelector<HTMLImageElement>('.profile-default');
      const avatarHtml = existingImg?.src
        ? `<img src="${existingImg.src}" class="ms-avatar-img" alt="Joshua Tuddenham">`
        : `<div class="ms-avatar-placeholder">JT</div>`;

      const tomAvatarUrl = 'https://i.insider.com/4efd9b8b69bedd682c000022?width=700&format=jpeg&auto=webp';

      const friends = [
        { img: tomAvatarUrl, name: 'Tom' },
        { img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/d/d8/Linkin_Park_-_From_Zero_Lead_Press_Photo_-_James_Minchin_III.jpg/330px-Linkin_Park_-_From_Zero_Lead_Press_Photo_-_James_Minchin_III.jpg', name: 'Linkin Park' },
        { img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/6/63/Limp_Bizkit_%28cropped%29.jpg/330px-Limp_Bizkit_%28cropped%29.jpg', name: 'Limp Bizkit' },
        { img: 'https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/Creed-2023.jpg/330px-Creed-2023.jpg', name: 'Creed' },
      ];
      const friendsHtml = friends.map(f =>
        `<div class="ms-friend-item">
          <img src="${f.img}" class="ms-friend-avatar-img" alt="${f.name}">
          <div class="ms-friend-name">${f.name}</div>
        </div>`
      ).join('');

      // ── Header ──────────────────────────────────────────────────────────
      const msHeader = document.createElement('div');
      msHeader.id = 'ms-header';
      msHeader.innerHTML = `
        <div class="ms-topbar">
          <a href="/?theme=myspace" class="ms-logo-link">
            <span class="ms-logo-my">my</span><span class="ms-logo-space">Space</span>
          </a>
          <div class="ms-search-bar">
            <span class="ms-search-label">Search: </span>
            <input type="text" class="ms-search-input" placeholder="People" />
            <select class="ms-search-type">
              <option>People</option><option>Web</option><option>Music</option>
            </select>
            <button class="ms-search-btn" type="button">Search</button>
          </div>
        </div>
        <div class="ms-navbar">
          <a href="/?theme=myspace">Home</a>
          <span class="ms-nav-sep">|</span>
          <a href="/blog?theme=myspace">Blog</a>
          <span class="ms-nav-sep">|</span>
          <a href="/projects?theme=myspace">Projects</a>
          <span class="ms-nav-sep">|</span>
          <span class="ms-nav-muted">Browse | Search | Invite | Mail | Favorites | Forum | Groups | Music</span>
          <span class="ms-nav-sep">|</span>
          <a href="#" id="ms-skin-btn">Change Skin</a>
        </div>
      `;
      document.body.insertBefore(msHeader, document.body.firstChild);

      document.getElementById('ms-skin-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        (document.getElementById('themeModal') as HTMLDialogElement | null)?.showModal();
      });

      document.getElementById('ms-btn-add')?.addEventListener('click', (e) => {
        e.preventDefault();
        alert('Joshua Tuddenham has been added to your friends!\n\nDon\'t forget to add him to your Top 8.');
      });
      document.getElementById('ms-btn-fave')?.addEventListener('click', (e) => {
        e.preventDefault();
        alert('Joshua Tuddenham has been added to your Favorites!');
      });
      document.getElementById('ms-btn-im')?.addEventListener('click', (e) => {
        e.preventDefault();
        alert('josht is Away:\n\n"currently debugging. brb"');
      });
      document.getElementById('ms-btn-block')?.addEventListener('click', (e) => {
        e.preventDefault();
        if (confirm('Are you sure you want to block Joshua Tuddenham?')) {
          const url = new URL(window.location.href);
          url.searchParams.delete('theme');
          window.location.href = url.toString();
        }
      });

      // ── Sidebar ─────────────────────────────────────────────────────────
      const msSidebar = document.createElement('div');
      msSidebar.id = 'ms-sidebar';
      msSidebar.innerHTML = `
        <div class="ms-box">
          <div class="ms-box-header">Joshua Tuddenham</div>
          <div class="ms-box-body">
            ${avatarHtml}
            <table class="ms-info-table">
              <tr><td><span class="ms-profile-name">Joshua Tuddenham</span></td></tr>
              <tr><td>London, UK</td></tr>
              <tr><td><b>Last Login:</b> Today, ${timeStr}</td></tr>
              <tr><td><b>Mood:</b> ${mood}</td></tr>
              <tr><td><b>Member Since:</b> 2020</td></tr>
            </table>
          </div>
        </div>

        <div class="ms-box">
          <div class="ms-box-header ms-box-header-blue">Contacting Joshua</div>
          <div class="ms-box-body">
            <table class="ms-contact-table">
              <tr>
                <td><a href="mailto:joshuaisaact@gmail.com" class="ms-contact-btn">📧 Send Message</a></td>
                <td><a href="#" class="ms-contact-btn" id="ms-btn-add">👥 Add to Friends</a></td>
              </tr>
              <tr>
                <td><a href="#" class="ms-contact-btn" id="ms-btn-fave">⭐ Add to Favorites</a></td>
                <td><a href="#" class="ms-contact-btn" id="ms-btn-im">💬 Instant Message</a></td>
              </tr>
              <tr>
                <td colspan="2"><a href="#" class="ms-contact-btn ms-block-btn" id="ms-btn-block">🚩 Block User</a></td>
              </tr>
            </table>
          </div>
        </div>

        <div class="ms-box">
          <div class="ms-box-header">Joshua's Friend Space</div>
          <div class="ms-box-body">
            <div class="ms-friends-count">Josh has <b>128</b> friends.</div>
            <div class="ms-friends-grid">${friendsHtml}</div>
            <div class="ms-view-all"><a href="/?theme=myspace">View All of Josh's Friends</a></div>
          </div>
        </div>
      `;
      msHeader.after(msSidebar);

      // ── Main (wrap existing content) ─────────────────────────────────────
      const msMain = document.createElement('div');
      msMain.id = 'ms-main';

      const profileHeader = document.createElement('div');
      profileHeader.className = 'ms-profile-header';
      profileHeader.innerHTML = `
        <span class="ms-profile-header-name">Joshua Tuddenham's Profile</span>
        <span class="ms-profile-header-status">🟢 Online Now!</span>
      `;
      msMain.appendChild(profileHeader);

      const injected = new Set(['ms-header', 'ms-sidebar']);
      Array.from(document.body.children).forEach(child => {
        if (!injected.has(child.id)) msMain.appendChild(child);
      });
      msSidebar.after(msMain);

      // ── Footer ───────────────────────────────────────────────────────────
      const msFooter = document.createElement('div');
      msFooter.id = 'ms-footer';
      msFooter.innerHTML = `
        <span>© 2006 MySpace.com. All Rights Reserved.</span>
        <div class="ms-footer-links">
          <a href="#">Privacy</a>
          <a href="#">Contact</a>
          <a href="#">About</a>
          <a href="#">Advertise</a>
          <a href="#">Terms</a>
        </div>
      `;
      document.body.appendChild(msFooter);
    }

    // Ceefax enhancements: header bar, scanlines, fastext, dithering
    if (siteTheme === 'ceefax') {
      const path = window.location.pathname.replace(/\/+$/, '') || '/';
      const pageMap: Record<string, string> = { '/': '100', '/blog': '200', '/projects': '300' };
      const hashSuffix = (p: string) =>
        String(Math.abs(p.split('').reduce((a, c) => (((a << 5) - a) + c.charCodeAt(0)) | 0, 0)) % 100).padStart(2, '0');
      const pageNum = pageMap[path]
        ?? (path.startsWith('/blog/') ? '2' + hashSuffix(path)
          : path.startsWith('/projects/') ? '3' + hashSuffix(path)
          : '100');

      const hdr = document.createElement('div');
      hdr.id = 'ceefax-header';
      document.body.insertBefore(hdr, document.body.firstChild);

      const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const now = new Date();
      const leftSpan = document.createElement('span');
      leftSpan.textContent = `P${pageNum} CEEFAX 1 ${pageNum} ${days[now.getDay()]} ${String(now.getDate()).padStart(2, ' ')} ${months[now.getMonth()]}`;
      hdr.appendChild(leftSpan);

      const timeSpan = document.createElement('span');
      timeSpan.className = 'ceefax-time';
      hdr.appendChild(timeSpan);

      const updateTime = () => {
        const d = new Date();
        timeSpan.textContent = `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}/${String(d.getSeconds()).padStart(2, '0')}`;
      };
      updateTime();
      setInterval(updateTime, 1000);

      const sl = document.createElement('div');
      sl.id = 'ceefax-scanlines';
      document.body.appendChild(sl);

      const ft = document.createElement('div');
      ft.id = 'ceefax-fastext';
      ft.innerHTML =
        '<a class="ceefax-key-red" href="/?theme=ceefax">Home</a>' +
        '<a class="ceefax-key-green" href="/blog?theme=ceefax">Blog</a>' +
        '<a class="ceefax-key-yellow" href="/projects?theme=ceefax">Projects</a>' +
        '<a class="ceefax-key-cyan" href="#" id="ceefax-theme-btn">Default Theme</a>';
      document.body.appendChild(ft);
      document.getElementById('ceefax-theme-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        const url = new URL(window.location.href);
        url.searchParams.delete('theme');
        window.location.href = url.toString();
      });

      import('../scripts/ceefaxDither').then(({ ceefaxDitherImages }) => ceefaxDitherImages());
    }
  </script>
</html>
